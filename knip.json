{
  "ignore": [
    "examples/**",
    ".claude/hooks/**",
    "prompts/**",
    "sources/**",
    "**/fixtures/**",
    "packages/trafilaturacore/native/index.js"
  ],
  "ignoreDependencies": [
    "cspell",
    "@cspell/dict-bash",
    "@cspell/dict-en-gb",
    "@cspell/dict-git",
    "@cspell/dict-rust"
  ],
  "ignoreWorkspaces": ["packages/trafilaturacore/native/npm/*"],
  "workspaces": {
    "packages/trafilaturacore": {
      "entry": "src/index.ts",
      "project": "src/**"
    },
    "packages/trafilaturacore/native": {
      "entry": "test/**/*.test.ts",
      "project": "test/**"
    }
  }
}
