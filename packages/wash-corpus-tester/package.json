{
  "name": "@htmlwasher/wash-corpus-tester",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Offline end-to-end corpus tester: runs htmlwasher over saved WCXB HTML fixtures and asserts security + page-type plausibility invariants.",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:corpus": "vitest run",
    "corpus": "tsx src/cli.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htmlwasher": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
