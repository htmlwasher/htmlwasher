{
  "name": "htmlwasher",
  "version": "0.0.0-alpha.0",
  "private": false,
  "type": "module",
  "description": "TypeScript port of Trafilatura with page-type-aware extraction and an ONNX page-type classifier (alpha).",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/classifier/model"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htmlparser2": "^10.0.0",
    "linkedom": "^0.18.12",
    "onnxruntime-node": "^1.23.0",
    "parse5": "^7.3.0"
  },
  "optionalDependencies": {
    "onnxruntime-web": "^1.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
