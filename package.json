{
  "name": "trafilaturacore-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm run fix && turbo build",
    "test": "turbo test",
    "lint": "biome check . && pnpm lint:md",
    "fix": "biome check . --fix --unsafe && biome format --write . && biome check . && pnpm fix:md",
    "format": "biome format --write . && pnpm fix:md",
    "check": "biome check . && pnpm lint:md",
    "lint:md": "markdownlint-cli2 \"**/*.md\" && prettier --check \"**/*.md\"",
    "fix:md": "markdownlint-cli2 --fix \"**/*.md\" && prettier --write \"**/*.md\"",
    "clone-sources": "bash clone-other-repos.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@cspell/dict-bash": "^4.2.3",
    "@cspell/dict-en-gb": "^5.0.29",
    "@cspell/dict-git": "^3.1.0",
    "@cspell/dict-rust": "^4.1.2",
    "@types/node": "^26.0.0",
    "cspell": "^10.0.1",
    "knip": "^5.66.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
