  ],
  "ignoreWords": ["Firecrawl", "Jina", "anthropics", "DOMCONTENTLOADE"],
  "flagWords": ["hte", "teh", "recieve", "seperate"],
  "ignorePaths": [
    "node_modules/**",
    "dist/**",
    ".git/**",
    "sources/**",
    "prompts/**",
    "**/*.lock",
    "pnpm-lock.yaml",
    "Cargo.lock",
    "training/data/**",
    "**/fixtures/**",
    "cspell.json"
  ],
  "patterns": [
    {
      "name": "url",
      "pattern": "https?://\\S+"
    }
  ],
  "ignoreRegExpList": ["url", "Urls", "Email", "HexValues", "UUID", "Base64"],
  "overrides": [
    {
      "filename": "**/fixtures/**",
      "enabled": false
    }
  ],
  "languageSettings": [
    {
      "languageId": "rust",
      "dictionaries": ["rust", "softwareTerms"]
    },
    {
      "languageId": "markdown",
      "language": "en,en-GB"
    },
    {
      "languageId": "typescript,javascript",
      "dictionaries": ["typescript", "node", "npm"]
    }
  ]
}
